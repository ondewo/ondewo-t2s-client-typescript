# Copyright 2021-2026 ONDEWO GmbH
#
# Configuration template for the ONDEWO T2S TypeScript client examples.
# This file is a NON-SECRET template: copy it, fill in real values locally, and
# never commit real credentials. Each example loads it via dotenv at startup.

# --- Connection -----------------------------------------------------------
# The grpc-web endpoint is assembled as <scheme>://ONDEWO_HOST:ONDEWO_PORT,
# where <scheme> is https when ONDEWO_USE_SECURE_CHANNEL=true, otherwise http.
# ONDEWO_PORT is the grpc-web (Envoy) proxy port in front of the T2S server.
ONDEWO_HOST=localhost
ONDEWO_PORT=8080

# --- Secure channel -------------------------------------------------------
ONDEWO_USE_SECURE_CHANNEL=false
# Optional path to a gRPC certificate file (leave blank for insecure/local).
ONDEWO_GRPC_CERT=

# --- Keycloak (headless ROPC + offline_access login) ----------------------
KEYCLOAK_URL=https://localhost:8443/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-t2s-cai-sdk-public
# The public SDK client uses no client secret; leave blank.
KEYCLOAK_CLIENT_SECRET=
# 2FA-exempt technical user credentials (fill in locally, never commit).
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak TLS certificate. Set to false only for a self-signed
# local Envoy/Keycloak.
KEYCLOAK_VERIFY_SSL=true

# --- T2S service-specific -------------------------------------------------
# Id of the T2S pipeline to synthesize with.
ONDEWO_T2S_PIPELINE_ID=
# Text to synthesize in the example run.
ONDEWO_T2S_TEXT=Hello from the ONDEWO T2S TypeScript client.
